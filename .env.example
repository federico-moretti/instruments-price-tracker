# WISHLISTS takes priority. Use a JSON array of Thomann wishlist URLs on one line.
WISHLISTS=["https://www.thomann.it/wishlist_4u_example.html?sort=user"]

# Fallback when WISHLISTS is not set.
# WISHLIST_URL=https://www.thomann.it/wishlist_4u_example.html?sort=user

# Notification provider: discord | telegram (optional — notifications are skipped when unset).
NOTIFY_PROVIDER=discord

# Discord (required when NOTIFY_PROVIDER=discord).
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Telegram (required when NOTIFY_PROVIDER=telegram).
# TELEGRAM_BOT_TOKEN=123456789:ABC...
# TELEGRAM_CHAT_ID=123456789
